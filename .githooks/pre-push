#!/bin/sh
# Gemini pre-push review — informational only, never blocks the push.
# Requires: Gemini CLI installed and authenticated.

STAT=$(git diff origin/main...HEAD --stat 2>/dev/null)

# Nothing to review
if [ -z "$STAT" ]; then
  exit 0
fi

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Gemini pre-push review"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

{
  cat <<'PROMPT'
You are reviewing a git diff for the Gridiron Brewing website — a static Astro site with
Sanity CMS, deployed to Cloudflare Pages. The site is for a craft brewery taproom in
Hampton, New Brunswick. Design tokens live in src/styles/global.css. Fonts: Anton
(display), Archivo (body), DM Mono (labels/kickers).

Flag ONLY the following — bullet points, be brief:
  • Obvious bugs or broken logic
  • Broken or invalid HTML/CSS structure
  • Unintended regressions (something that was working likely now broken)
  • Accessibility issues (missing alt text, broken aria attributes, etc.)
  • Anything that clearly contradicts the apparent intent of the change

Do NOT flag: style preferences, formatting, minor wording, or things that are a matter of taste.
If nothing is wrong, say so in one line.

Files changed:
PROMPT
  git diff origin/main...HEAD --stat
  echo ""
  echo "Full diff:"
  git diff origin/main...HEAD
} | gemini -m pro

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Push proceeding. Review above before Cloudflare deploys."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

exit 0
