/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; img-src 'self' data: https://cdn.sanity.io https://*.cdninstagram.com https://*.fbcdn.net https://*.behold.so; media-src https://*.cdninstagram.com https://*.fbcdn.net; script-src 'self' 'unsafe-inline' https://w.behold.so; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' https://*.api.sanity.io https://*.apicdn.sanity.io https://*.behold.so; frame-src https://maps.google.com https://www.google.com; object-src 'none'; base-uri 'self'

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable
