---
import Layout from '../layouts/Layout.astro';
import BeerTag from '../components/BeerTag.astro';
import { beers as allBeers } from '../data/beers';
import { TAP_COUNT } from '../utils/constants';

// Already onTap-first from GROQ; just drop hidden
const beers = allBeers.filter(b => b.tag !== 'hidden');

const description = 'Twelve craft beers on tap right now — six flagships that never leave, plus a rotating cast of seasonals and guest taps. Brewed in Hampton, NB.';
---

<Layout title="The Pour List — Gridiron Brewing" description={description} activeNav="Drinks">
  <section class="page-hero grain">
    <span class="kicker">Craft Beer, Fresh · Hampton, NB</span>
    <h1>The Pour List</h1>
    <p>{TAP_COUNT} beers on tap right now — six flagships that never leave, plus a rotating cast of seasonals and guest taps. Wine, cider, cocktails, and non-alcoholic options also available.</p>
  </section>

  <div class="tap-section">
    <div class="tap-controls">
      <div class="inner">
        <div class="filter-group">
          <span>Availability</span>
          <div class="chips">
            <button class="chip active" data-filter="ontap" data-value="all">All</button>
            <button class="chip" data-filter="ontap" data-value="true">On Tap</button>
          </div>
        </div>
        <div class="filter-group">
          <span>Style</span>
          <div class="chips">
            <button class="chip active" data-filter="style" data-value="all">All</button>
            <button class="chip" data-filter="style" data-value="lager">Lager</button>
            <button class="chip" data-filter="style" data-value="amber">Amber &amp; Pale</button>
            <button class="chip" data-filter="style" data-value="ipa">IPA</button>
            <button class="chip" data-filter="style" data-value="dark">Dark</button>
          </div>
        </div>
        <div class="filter-group">
          <span>Strength</span>
          <div class="chips">
            <button class="chip active" data-filter="abv" data-value="all">All</button>
            <button class="chip" data-filter="abv" data-value="session">Session &lt;5%</button>
            <button class="chip" data-filter="abv" data-value="standard">Standard 5–6.5%</button>
            <button class="chip" data-filter="abv" data-value="strong">Strong 6.5%+</button>
          </div>
        </div>
        <div class="tap-count" data-tap-count><b>{TAP_COUNT}</b> beers on tap</div>
        <div class="tap-count price-tagline">$9 · 16oz &nbsp;|&nbsp; $10 · 20oz</div>
      </div>
    </div>

    <section class="band-paper2">
      <div class="section-sm">
        <div class="beer-grid" data-tap-grid>
          {beers.map((beer) => (
            <article class={`beer-card${!beer.onTap ? ' off-tap' : ''}`} data-style={beer.styleCat} data-abv={beer.abv} data-ontap={beer.onTap}>
              <div class="beer-can" style="background:#e8d9b9;">
                <div class="can" style={`background:${beer.canBg};`}>
                  <span class={`cn${beer.lightText ? ' cn-light' : ''}`}>
                    {beer.canLabel[0]}<br />{beer.canLabel[1]}
                  </span>
                </div>
              </div>
              <div class="beer-info">
                <span class="style">{beer.style}</span>
                <h3>{beer.name}</h3>
                <p class="desc">{beer.desc}</p>
                <div class="beer-specs">
                  <div class="spec"><span>ABV</span><b>{beer.abv}%</b></div>
                  <div class="spec"><span>IBU</span><b>{beer.ibu}</b></div>
                  <div class="tag-stack">
                    <BeerTag tag={beer.tag} />
                    <span class={`tag${beer.onTap ? ' ontap' : ' ask'}`}>{beer.onTap ? 'On Tap' : 'Ask Us'}</span>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
        <div class="no-results">No beers match those filters — try loosening up.</div>
      </div>
    </section>
  </div>

  <section class="section-md">
    <div class="also-menu-wrap">
      <h2 class="also-menu-h reveal">Also On The Menu</h2>

      <div class="also-menu-group reveal d1">
        <span class="kicker">Wine</span>
        <div class="drinks-list">
          <div class="drink-row">
            <div><h4>House White</h4></div>
            <div class="drink-price">$7 <span>6 oz</span> · $10 <span>9 oz</span></div>
          </div>
          <div class="drink-row">
            <div><h4>House Red</h4></div>
            <div class="drink-price">$7 <span>6 oz</span> · $10 <span>9 oz</span></div>
          </div>
        </div>
      </div>

      <div class="also-menu-group reveal d1">
        <span class="kicker">Cider &amp; Cocktails</span>
        <div class="drinks-list">
          <div class="drink-row">
            <div><h4>Yip Cider</h4></div>
            <div class="drink-price">$7 <span>can</span></div>
          </div>
          <div class="drink-row">
            <div><h4>Kingston Creek Cider</h4></div>
            <div class="drink-price">$7 <span>6 oz</span> · $10 <span>9 oz</span></div>
          </div>
          <div class="drink-row">
            <div><h4>Caesar</h4></div>
            <div class="drink-price">$7 <span>6 oz</span> · $10 <span>9 oz</span></div>
          </div>
          <div class="drink-row">
            <div><h4>Moscow Mule</h4></div>
            <div class="drink-price">$7 <span>6 oz</span> · $10 <span>9 oz</span></div>
          </div>
          <div class="drink-row">
            <div><h4>Dave Matthews</h4></div>
            <div class="drink-price">$7 <span>6 oz</span> · $10 <span>9 oz</span></div>
          </div>
        </div>
      </div>

      <div class="also-menu-group reveal d2">
        <span class="kicker">Non-Alcoholic</span>
        <div class="drinks-list">
          <div class="drink-row">
            <div>
              <h4>N/A Beer &amp; Drinks</h4>
              <p>Canned non-alcoholic options available — ask your server for today's selection.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="band-amber">
    <div class="section flights-band">
      <div class="split2">
        <div>
          <span class="kicker kicker-amber-deep">Flights &amp; Fills</span>
          <h2 class="display-ink-md">Best Tasted<br />Fresh, On The River</h2>
          <p class="copy">Pull up a flight on the patio — five pours, your pick. Every one is brewed and poured right here in Hampton, with cans and growler fills to take home.</p>
          <div class="stack-buttons">
            <a class="btn btn-ink-deep" href="/visit">Plan Your Visit →</a>
          </div>
        </div>
        <div>
          <img class="photo flights-img" src="/assets/photos/beer-flight-table.webp" alt="A flight of Gridiron beers on the patio" width="1248" height="835" loading="lazy" decoding="async" />
        </div>
      </div>
    </div>
  </section>
</Layout>


<script>
  (function () {
    const grid = document.querySelector('[data-tap-grid]');
    if (!grid) return;
    const cards = Array.from(grid.querySelectorAll('.beer-card')) as HTMLElement[];
    const state: Record<string, string> = { style: 'all', abv: 'all', ontap: 'all' };
    const countEl = document.querySelector('[data-tap-count]');
    const noRes = document.querySelector('.no-results') as HTMLElement | null;

    function abvBucket(v: number) {
      if (v < 5) return 'session';
      if (v <= 6.5) return 'standard';
      return 'strong';
    }

    function apply() {
      let shown = 0;
      cards.forEach((card) => {
        const styleOk = state.style === 'all' || card.dataset.style === state.style;
        const abvOk = state.abv === 'all' || abvBucket(parseFloat(card.dataset.abv || '0')) === state.abv;
        const ontapOk = state.ontap === 'all' || card.dataset.ontap === state.ontap;
        const ok = styleOk && abvOk && ontapOk;
        card.classList.toggle('hidden', !ok);
        if (ok) shown++;
      });
      if (countEl) countEl.innerHTML = `<b>12</b> beers on tap`;
      if (noRes) noRes.style.display = shown === 0 ? 'block' : 'none';
    }

    document.querySelectorAll('[data-filter]').forEach((chip) => {
      chip.addEventListener('click', () => {
        const el = chip as HTMLElement;
        const group = el.dataset.filter!;
        const val = el.dataset.value!;
        state[group] = val;
        document.querySelectorAll(`[data-filter="${group}"]`).forEach((c) =>
          c.classList.toggle('active', c === chip)
        );
        apply();
      });
    });

    apply();
  })();
</script>
