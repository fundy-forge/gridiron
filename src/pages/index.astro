---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import OnTap from '../components/OnTap.astro';
import Taproom from '../components/Taproom.astro';
import Events from '../components/Events.astro';
import Community from '../components/Community.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import { events } from '../data/events';
import { activeSchedule } from '../data/settings';
import { buildEventSchemas } from '../utils/eventSchema';

// Emit Event JSON-LD for the upcoming events surfaced on the homepage
const homeEventSchemas = buildEventSchemas(events.filter(e => !e.recurring).slice(0, 4));
---

<Layout
  title="Gridiron Brewing — Hampton, New Brunswick"
  description="Small-batch craft brewery and taproom in Hampton, NB. 12 beers on tap, patio on the Kennebecasis River, live music most weekends. 25 minutes from Saint John."
  hours={activeSchedule}
>
  <Fragment slot="head">
    {homeEventSchemas.map(schema => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </Fragment>

  <Hero />
  <OnTap />
  <Taproom />
  <About />
  <Events />
  <InstagramFeed />
  <Community />
</Layout>
