---
import Layout from '../layouts/Layout.astro';
import eventsData from '../data/events.json';

const upcoming = eventsData.events.filter(e => !e.recurring);
const recurring = eventsData.events.filter(e => e.recurring);

function gcalUrl(ev: { title: string; desc: string; calDate: string }): string {
  const dt = ev.calDate.replace(/[-:]/g, '');
  const end = (() => {
    const d = new Date(ev.calDate);
    d.setHours(d.getHours() + 2);
    return d.toISOString().replace(/[-:]/g, '').slice(0, 15);
  })();
  const p = new URLSearchParams({
    action: 'TEMPLATE',
    text: ev.title,
    dates: `${dt}/${end}`,
    details: ev.desc,
    location: 'Gridiron Brewing, Hampton, NB',
  });
  return `https://calendar.google.com/calendar/render?${p.toString()}`;
}

function icsUri(ev: { title: string; desc: string; calDate: string }): string {
  const fmt = (d: Date) =>
    d.toISOString().replace(/[-:]/g, '').slice(0, 15) + 'Z';
  const start = new Date(ev.calDate);
  const end = new Date(start);
  end.setHours(end.getHours() + 2);
  const uid = `${ev.calDate.replace(/\W/g, '')}-gridiron@gridironbrewing.ca`;
  const lines = [
    'BEGIN:VCALENDAR',
    'VERSION:2.0',
    'BEGIN:VEVENT',
    `DTSTART:${fmt(start)}`,
    `DTEND:${fmt(end)}`,
    `SUMMARY:${ev.title}`,
    `DESCRIPTION:${ev.desc.replace(/\n/g, '\\n')}`,
    'LOCATION:Gridiron Brewing, Hampton, NB',
    `UID:${uid}`,
    'END:VEVENT',
    'END:VCALENDAR',
  ].join('\r\n');
  return `data:text/calendar;charset=utf-8,${encodeURIComponent(lines)}`;
}
---

<Layout title="Events & Music — Gridiron Brewing" activeNav="Events">

  <section class="page-hero grain">
    <span class="kicker">What's On · Hampton, NB</span>
    <h1>Events &amp; Music</h1>
    <p>Live music most weekends, trivia every Tuesday, food trucks on the patio, and a few surprises along the way. Always free to get in.</p>
  </section>

  <!-- Upcoming special events -->
  {upcoming.length > 0 && (
    <section class="section" id="ev-upcoming">
      <div class="section-head">
        <span class="kicker reveal">Mark Your Calendar</span>
        <h2 class="reveal d1">Coming Up</h2>
      </div>
      <div class="event-list ev-list-img">
        {upcoming.map((ev, i) => (
          <div class={`event-row reveal${i > 0 ? ` d${Math.min(i, 3)}` : ''}`} data-caldate={ev.calDate || ''}>
            <!-- Thumbnail column -->
            <div class="ev-thumb" data-src={ev.image || ''} data-alt={ev.title}>
              <img src={ev.image || '/assets/events/placeholder.svg'} alt={ev.image ? ev.title : ''} loading="lazy" decoding="async" />
            </div>
            <!-- Body: date badge + text -->
            <div class="event-body">
              {ev.day && (
                <div class="ev-date-badge">
                  <span class="d">{ev.day}</span>
                  <span class="m">{ev.month}</span>
                </div>
              )}
              <h4>{ev.title}</h4>
              <p>{ev.desc}</p>
              {ev.calDate && (
                <div class="cal-links">
                  <a class="cal-btn" href={gcalUrl(ev)} target="_blank" rel="noopener">+ Google Calendar</a>
                  <a class="cal-btn" href={icsUri(ev)} download={`${ev.title.replace(/\s+/g, '-')}.ics`}>+ Apple / Outlook</a>
                </div>
              )}
            </div>
            <div class="event-meta">
              {ev.when}{ev.cover && <><br /><span class="free">{ev.cover}</span></>}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Recurring weekly events -->
  <section class="band-paper2 section">
    <div class="section-head">
      <span class="kicker reveal">Every Week</span>
      <h2 class="reveal d1">Regular Nights</h2>
      <p class="lead reveal d1">These happen on the regular — no date required. Just show up.</p>
    </div>
    <div class="event-list ev-list-img">
      {recurring.map((ev, i) => (
        <div class={`event-row reveal${i > 0 ? ` d${Math.min(i, 3)}` : ''}`}>
          <div class="ev-thumb" data-src={ev.image || ''} data-alt={ev.title}>
            <img src={ev.image || '/assets/events/placeholder.svg'} alt={ev.image ? ev.title : ''} loading="lazy" decoding="async" />
          </div>
          <div class="event-body">
            <div class="ev-rec-badge">↻ Weekly</div>
            <h4>{ev.title}</h4>
            <p>{ev.desc}</p>
          </div>
          <div class="event-meta">
            {ev.when}{ev.cover && <><br /><span class="free">{ev.cover}</span></>}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA band -->
  <section class="band-dark">
    <div class="section" style="padding:72px 32px;text-align:center;">
      <span class="kicker" style="color:var(--amber-bright);">Stay In The Loop</span>
      <h2 class="display" style="font-size:clamp(32px,4vw,54px);color:var(--cream);margin:16px 0 20px;line-height:0.92;">Follow Along<br />On Instagram</h2>
      <p style="font-size:17px;color:rgba(250,243,228,.74);max-width:480px;margin:0 auto 32px;line-height:1.6;">Tap releases, last-minute food trucks, live music announcements — it all lands on Instagram first.</p>
      <a class="btn btn-amber" href="https://www.instagram.com/gridironbrewing/" target="_blank" rel="noopener">@gridironbrewing →</a>
    </div>
  </section>

  <!-- Lightbox -->
  <div id="ev-lightbox" aria-hidden="true" role="dialog" aria-modal="true">
    <img id="ev-lightbox-img" src="" alt="" />
  </div>

</Layout>

<script>
  // Lightbox
  const lightbox = document.getElementById('ev-lightbox');
  const lbImg = document.getElementById('ev-lightbox-img') as HTMLImageElement | null;

  function openLightbox(src: string, alt: string) {
    if (!lightbox || !lbImg || !src) return;
    lbImg.src = src;
    lbImg.alt = alt;
    lightbox.classList.add('open');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    if (!lightbox) return;
    lightbox.classList.remove('open');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.ev-thumb[data-src]').forEach((el) => {
    const src = el.getAttribute('data-src') || '';
    const alt = el.getAttribute('data-alt') || '';
    if (!src) return;
    el.addEventListener('click', () => openLightbox(src, alt));
  });

  lightbox?.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });

  // Auto-hide past events
  const now = new Date();
  const upcomingSection = document.getElementById('ev-upcoming');
  if (upcomingSection) {
    let visible = 0;
    upcomingSection.querySelectorAll('.event-row[data-caldate]').forEach((row) => {
      const d = (row as HTMLElement).dataset.caldate;
      if (d && new Date(d) < now) {
        (row as HTMLElement).style.display = 'none';
      } else {
        visible++;
      }
    });
    if (visible === 0) upcomingSection.style.display = 'none';
  }
</script>

<style>
  /* Override the event-row first column for image lists */
  .ev-list-img .event-row {
    grid-template-columns: 220px 1fr auto;
  }

  /* Thumbnail cell */
  .ev-thumb {
    width: 220px;
    height: 150px;
    border-radius: 8px;
    overflow: hidden;
    cursor: zoom-in;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--paper-2, #e8dcc8);
  }
  .ev-thumb[data-src=""] { cursor: default; }
  .ev-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease, filter 0.35s ease;
  }
  .ev-thumb:hover img {
    transform: scale(1.06);
    filter: brightness(1.08);
  }

  /* Fallback when no image */
  .ev-thumb-date {
    font-family: 'Anton', sans-serif;
    text-align: center;
    line-height: 0.85;
  }
  .ev-thumb-date .d { font-size: 38px; display: block; }
  .ev-thumb-date .m { font-size: 14px; color: var(--amber); display: block; }
  .rec-icon { font-size: 32px; color: var(--amber); }

  /* Inline date badge inside event-body */
  .ev-date-badge {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-bottom: 6px;
  }
  .ev-date-badge .d {
    font-family: 'Anton', sans-serif;
    font-size: 28px;
    line-height: 1;
    color: var(--ink);
  }
  .ev-date-badge .m {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.06em;
    color: var(--amber);
    text-transform: uppercase;
  }
  .ev-rec-badge {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 6px;
  }

  /* Calendar links */
  .cal-links {
    display: flex;
    gap: 10px;
    margin-top: 10px;
    flex-wrap: wrap;
  }
  .cal-btn {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--amber);
    border: 1px solid var(--amber);
    border-radius: 4px;
    padding: 4px 10px;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .cal-btn:hover {
    background: var(--amber);
    color: var(--ink);
  }

  /* Lightbox */
  #ev-lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.9);
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
  }
  #ev-lightbox.open { display: flex; }
  #ev-lightbox-img {
    max-width: 92vw;
    max-height: 88vh;
    object-fit: contain;
    border-radius: 6px;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.7);
  }

  /* Mobile */
  @media (max-width: 640px) {
    .ev-list-img .event-row {
      grid-template-columns: 90px 1fr;
      gap: 14px;
    }
    .ev-thumb {
      width: 90px;
      height: 80px;
    }
    .event-meta {
      grid-column: 2;
      text-align: left;
    }
  }
</style>
