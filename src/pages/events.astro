---
import Layout from '../layouts/Layout.astro';
import Lightbox from '../components/Lightbox.astro';
import { events } from '../data/events';
import { buildEventSchemas, gcalUrl, icsUri } from '../utils/eventSchema';

const upcoming = events.filter(e => !e.recurring);
const recurring = events.filter(e => e.recurring);
const eventSchemas = buildEventSchemas(upcoming);

const nextEvent = upcoming.find(e => e.image);
const ogImage = nextEvent?.imageFull;

const description = 'Live music most weekends, trivia every Tuesday, food trucks on the patio. Gather your crew and head on over! Hampton, NB.';
---

<Layout title="Events & Music — Gridiron Brewing" description={description} ogImage={ogImage} activeNav="Events">
  <Fragment slot="head">
    {eventSchemas.map(schema => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </Fragment>

  <section class="page-hero grain">
    <span class="kicker">What's On · Hampton, NB</span>
    <h1>Events &amp; Music</h1>
    <p>Live music most weekends, trivia every Tuesday, food trucks on the patio, and a few surprises along the way. Gather your crew and head on over!</p>
  </section>

  {upcoming.length > 0 && (
    <section class="section" id="ev-upcoming">
      <div class="section-head">
        <span class="kicker reveal">Mark Your Calendar</span>
        <h2 class="reveal d1">Coming Up</h2>
      </div>
      <div class="event-list ev-list-img">
        {upcoming.map((ev, i) => (
          <div class={`event-row reveal${i > 0 ? ` d${Math.min(i, 3)}` : ''}`} data-caldate={ev.calDate || ''}>
            <div class="ev-thumb lb-trigger" data-src={ev.imageFull || ''} data-alt={ev.title}>
              <img src={ev.image || '/assets/events/placeholder.svg'} alt={ev.image ? ev.title : ''} loading="lazy" decoding="async" />
            </div>
            <div class="event-body">
              {ev.day && (
                <div class="ev-date-badge">
                  <span class="d">{ev.day}</span>
                  <span class="m">{ev.month}</span>
                </div>
              )}
              <h4>{ev.title}</h4>
              <p>{ev.desc}</p>
              {ev.calDate && (
                <div class="cal-links">
                  <a class="cal-btn" href={gcalUrl(ev)} target="_blank" rel="noopener">+ Google Calendar</a>
                  <a class="cal-btn" href={icsUri(ev)} download={`${ev.title.replace(/\s+/g, '-')}.ics`}>+ Apple / Outlook</a>
                </div>
              )}
            </div>
            <div class="event-meta">
              {ev.when}{ev.cover && <><br /><span class="free">{ev.cover}</span></>}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="band-paper2">
    <div class="section">
      <div class="section-head">
        <span class="kicker reveal">Every Week</span>
        <h2 class="reveal d1">Regular Nights</h2>
        <p class="lead reveal d1">These happen on the regular — no date required. Just show up.</p>
      </div>
      <div class="event-list ev-list-img">
        {recurring.map((ev, i) => (
          <div class={`event-row reveal${i > 0 ? ` d${Math.min(i, 3)}` : ''}`}>
            <div class="ev-thumb lb-trigger" data-src={ev.imageFull || ''} data-alt={ev.title}>
              <img src={ev.image || '/assets/events/placeholder.svg'} alt={ev.image ? ev.title : ''} loading="lazy" decoding="async" />
            </div>
            <div class="event-body">
              <div class="ev-rec-badge">↻ Weekly</div>
              <h4>{ev.title}</h4>
              <p>{ev.desc}</p>
            </div>
            <div class="event-meta">
              {ev.when}{ev.cover && <><br /><span class="free">{ev.cover}</span></>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Lightbox id="ev-lightbox" />
</Layout>

<script>
  import { bindLightbox } from '../utils/lightbox';
  bindLightbox('ev-lightbox', '.lb-trigger[data-src]:not([data-src=""])');

  // Auto-hide past events
  const now = new Date();
  const upcomingSection = document.getElementById('ev-upcoming');
  if (upcomingSection) {
    let visible = 0;
    upcomingSection.querySelectorAll('.event-row[data-caldate]').forEach((row) => {
      const d = (row as HTMLElement).dataset.caldate;
      if (d && new Date(d) < now) {
        (row as HTMLElement).style.display = 'none';
      } else {
        visible++;
      }
    });
    if (visible === 0) upcomingSection.style.display = 'none';
  }
</script>

<style>
  .ev-list-img .event-row {
    grid-template-columns: 220px 1fr auto;
  }

  .ev-thumb {
    width: 220px;
    height: 150px;
    border-radius: 8px;
    overflow: hidden;
    cursor: zoom-in;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--paper-2, #e8dcc8);
  }
  .ev-thumb[data-src=""] { cursor: default; }
  .ev-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease, filter 0.35s ease;
  }
  .ev-thumb:hover img {
    transform: scale(1.06);
    filter: brightness(1.08);
  }

  .ev-date-badge {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-bottom: 6px;
  }
  .ev-date-badge .d {
    font-family: 'Anton', sans-serif;
    font-size: 28px;
    line-height: 1;
    color: var(--ink);
  }
  .ev-date-badge .m {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.06em;
    color: var(--amber);
    text-transform: uppercase;
  }
  .ev-rec-badge {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 6px;
  }

  .cal-links {
    display: flex;
    gap: 10px;
    margin-top: 10px;
    flex-wrap: wrap;
  }
  .cal-btn {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--amber);
    border: 1px solid var(--amber);
    border-radius: 4px;
    padding: 4px 10px;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .cal-btn:hover {
    background: var(--amber);
    color: var(--ink);
  }

  @media (max-width: 520px) {
    .ev-list-img .event-row {
      grid-template-columns: 90px 1fr;
      gap: 14px;
    }
    .ev-thumb {
      width: 90px;
      height: 80px;
    }
    .event-meta {
      grid-column: 2;
      text-align: left;
    }
  }
</style>
