---
import Layout from '../layouts/Layout.astro';
import PhoneIcon from '../components/icons/PhoneIcon.astro';
import MailIcon from '../components/icons/MailIcon.astro';
import { activeSchedule } from '../data/settings';

const trucks = [
// ... (trucks array remains same)
  {
    image: '/assets/food/sakura-hibachi.webp', width: 669, height: 486,
    name: 'Sakura Hibachi', cuisine: 'Japanese Cuisine',
    desc: 'Fresh hibachi and Japanese favourites, cooked right outside on the patio.',
    fb: 'https://www.facebook.com/profile.php?id=61550952335901',
  },
  {
    image: '/assets/food/stoked-pizza.webp', width: 664, height: 435,
    name: 'Stoked Artisan Pizza', cuisine: 'Artisan Pizza',
    desc: 'Wood-fired artisan pizzas made fresh to order. The perfect pairing for a cold pint.',
    fb: 'https://www.facebook.com/stokedpizzanb',
  },
  {
    image: '/assets/food/costa-nachos.webp', width: 819, height: 486,
    name: 'Costa Nachos', cuisine: 'Nachos & Mexican Fare',
    desc: 'Loaded nachos and bold Mexican flavours. Hard to stop at one round.',
    fb: 'https://www.facebook.com/costanacho',
  },
];

const infoCards = [
  {
    title: 'Parking',
    body: 'Our on-site spots fill up fast, so getting here early is your best bet. But don\'t fret if the lot is full—there is side street parking right behind the brewery, and the River Centre public lot is just a short, easy stroll away.',
  },
  {
    title: 'Kids & Families',
    body: 'Bring the whole crew! Families are always welcome here. We keep the board games stacked, the colouring activities ready, and a growing lineup of tasty non-alcoholic drinks on hand to keep everyone smiling.',
  },
  {
    title: 'Accessibility',
    body: "We want everyone to feel at home at Gridiron. A ramp provides easy access up to the deck, though there is a small lift at the interior entry. We are actively working on improving accessibility throughout the whole building to level things out. If you have any questions before you head over, just give us a ring and we'll do everything we can to help you settle in.",
  },
];

const description = 'Visit Gridiron Brewing at 1051 Main Street, Hampton, NB. Twelve taps, food trucks on the patio, room for the whole crew — dogs and kids included.';
---

<Layout title="Visit — Gridiron Brewing" description={description} activeNav="Visit" hours={activeSchedule}>
  <section class="page-hero grain">
    <span class="kicker">The Taproom · Hampton, NB</span>
    <h1>Come Visit</h1>
    <p>1051 Main Street, Hampton, New Brunswick. Twelve taps, food trucks on occasion, a patio, and room for the whole crew — dogs and kids included.</p>
  </section>

  <section class="band-dark">
    <div class="section visit-hours-grid">
      <div class="reveal">
        <span class="kicker kicker-amber-bright">Opening Hours</span>
        <h2 class="display-cream-sm">When We're Pouring</h2>
        {activeSchedule && (
          <>
            <p class="summer-hours-label">{activeSchedule.title}</p>
            <table class="hours-table" id="hours">
              {activeSchedule.days.map((h) => (
                <tr>
                  <td>{h.day}</td>
                  <td class={h.isClosed ? "closed" : ""}>
                    {h.isClosed ? "Closed" : (
                      <>
                        {h.opens} — {h.closes}
                        {h.showIsh && <span class="ish"> 'ish</span>}
                      </>
                    )}
                  </td>
                </tr>
              ))}
            </table>
            <p class="hours-note">{activeSchedule.holidayNote}</p>
            <a class="hours-ig" href="https://www.instagram.com/gridironbrewing/" target="_blank" rel="noopener">@gridironbrewing →</a>
          </>
        )}
      </div>
      <div class="reveal d1">
        <span class="kicker kicker-amber-bright">Find Us</span>
        <h2 class="display-cream-sm">The Address</h2>
        <p class="visit-address">1051 Main Street<br />Hampton, New Brunswick</p>
        <div class="visit-contact">
          <span><PhoneIcon /> (506) 832-4592</span>
          <span><MailIcon /> info@gridironbrewing.com</span>
        </div>
        <div class="visit-cta-row">
          <a class="btn btn-amber" href="#directions">Get Directions →</a>
          <a class="btn btn-ghost-cream" href="tel:+15068324592">Call Ahead</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="directions">
    <div class="section-head">
      <span class="kicker reveal">Getting Here</span>
      <h2 class="reveal d1">On The River</h2>
      <p class="lead reveal d1">Twenty-five minutes from uptown Saint John, right where Main Street bends to meet the water. Easy to find, easier to stay.</p>
    </div>
    <div class="visit-directions-grid">
      <div class="reveal map-frame">
        <iframe
          src="https://maps.google.com/maps?q=1051+Main+Street,+Hampton,+New+Brunswick,+Canada&t=k&output=embed"
          width="100%"
          height="420"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Gridiron Brewing — 1051 Main Street, Hampton, NB">
        </iframe>
      </div>
      <div class="info-stack">
        {infoCards.map((card, i) => (
          <div class={`info-card reveal d${i + 1}`}>
            <h4 class="label">{card.title}</h4>
            <p>{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="food">
    <div class="section-head">
      <span class="kicker reveal">Perfect Pairings</span>
      <h2 class="reveal d1">Food Trucks &amp; Hometown Eats</h2>
      <p class="lead reveal d1">From the first thaw of spring straight through to the crisp early fall, we've got a stellar lineup of local food trucks rolling right up to the patio on the weekends. Keep an eye on our social media to see who's parked out front each week!</p>
    </div>

    <div class="visit-food-grid food-grid-spacing">
      {trucks.map((t, i) => (
        <div class={`food-card reveal${i > 0 ? ` d${i}` : ''}`}>
          <div class="food-card-img">
            <img src={t.image} alt={`${t.name} food truck`} width={t.width} height={t.height} loading="lazy" decoding="async" />
          </div>
          <div class="food-card-body">
            <h3>{t.name}</h3>
            <p class="cuisine">{t.cuisine}</p>
            <p>{t.desc}</p>
            <a href={t.fb} target="_blank" rel="noopener" class="fb-link">Follow on Facebook →</a>
          </div>
        </div>
      ))}
    </div>

    <div class="reveal byo-band">
      <p>Got a craving for something else? You are always welcome to grab takeout from your favorite spot here in Hampton and bring it right to your table. As long as you've got a cold glass from our bar in your hand, we want you to make yourself at home.</p>
    </div>
  </section>

  <section class="band-amber" id="private">
    <div class="section visit-private-grid">
      <div class="reveal private-img">
        <img src="/assets/photos/crowded-bar.webp" alt="Gridiron Brewing packed for an event" width="800" height="608" loading="lazy" decoding="async" />
      </div>
      <div>
        <span class="kicker kicker-amber-deep reveal">Gather 'Round</span>
        <h2 class="display-ink reveal d1">Book The<br />Back Room</h2>
        <p class="body-on-amber reveal d1">Whether it's a milestone 50th birthday bash, an office get-together, or just a Tuesday night with forty of your closest friends, we've got the space to make it special. The back room comfortably seats 40, the patio is ready for the overflow, and the best part? We'll custom-build a fresh beer flight around exactly what you're celebrating.</p>
        <div class="stack-buttons reveal d2">
          <a class="btn btn-ink-deep" href="mailto:info@gridironbrewing.com">Let's Plan Your Get-Together →</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .cream-ghost { color: var(--cream); }
  .hours-ig { display: inline-block; margin-top: 10px; font-family: 'DM Mono', monospace; font-size: 12px; letter-spacing: .1em; text-transform: uppercase; color: var(--amber-bright); text-decoration: none; transition: color .15s; }
  .hours-ig:hover { color: var(--cream); }
  .food-grid-spacing { margin-bottom: 48px; }
  iframe { border: 0; display: block; }
</style>

<script>
  const today = new Intl.DateTimeFormat('en-CA', { weekday: 'long', timeZone: 'America/Moncton' }).format(new Date());
  document.querySelectorAll('#hours tr').forEach((tr) => {
    const first = tr.firstElementChild;
    if (first && first.textContent?.trim() === today) tr.classList.add('today');
  });
</script>
