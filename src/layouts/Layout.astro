---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  activeNav?: string;
}

const { title = 'Gridiron Brewing — Hampton, New Brunswick', activeNav } = Astro.props;

const siteUrl = 'https://gridironbrewing.ca';
const pathname = Astro.url.pathname;

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'Brewery'],
  name: 'Gridiron Brewing',
  url: siteUrl,
  telephone: '+15068324592',
  email: 'info@gridironbrewing.com',
  image: `${siteUrl}/assets/logos/logo-favicon.png`,
  priceRange: '$$',
  description: 'Small-batch craft brewery and taproom in Hampton, New Brunswick — 25 minutes from uptown Saint John. Cold pints, patio on the Kennebecasis, live music most weekends.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '1051 Main Street',
    addressLocality: 'Hampton',
    addressRegion: 'NB',
    addressCountry: 'CA',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 45.5288,
    longitude: -65.8330,
  },
  areaServed: [
    { '@type': 'City', name: 'Hampton',    addressRegion: 'NB', addressCountry: 'CA' },
    { '@type': 'City', name: 'Saint John', addressRegion: 'NB', addressCountry: 'CA' },
  ],
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Tuesday',   opens: '16:00', closes: '20:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Wednesday', opens: '16:00', closes: '20:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Thursday',  opens: '12:00', closes: '20:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Friday',    opens: '12:00', closes: '21:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Saturday',  opens: '12:00', closes: '21:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Sunday',    opens: '12:00', closes: '19:00' },
  ],
  sameAs: [
    'https://www.instagram.com/gridironbrewing/',
    'https://www.facebook.com/gridironbrewing/',
    'https://untappd.com/MatchstickBeerFactory',
  ],
};

const pageLabels: Record<string, string> = {
  '/beers': 'Drinks',
  '/events': 'Events',
  '/visit': 'Visit',
};
const pageLabel = Object.entries(pageLabels).find(([k]) => pathname.startsWith(k))?.[1];

const breadcrumb = pageLabel ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',     item: siteUrl },
    { '@type': 'ListItem', position: 2, name: pageLabel,  item: `${siteUrl}${pathname}` },
  ],
} : null;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/assets/logos/logo-favicon.png" />
    <link rel="apple-touch-icon" href="/assets/logos/logo-favicon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Gridiron Brewing — Small-batch craft beer brewed in Hampton, New Brunswick. Taproom on the Kennebecasis. Cold pints, cozy place." />
    <title>{title}</title>
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Gridiron Brewing" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Small-batch craft beer brewed in Hampton, New Brunswick. Cold pints, cozy place." />
    <meta property="og:image" content="/assets/logos/logo-favicon.png" />
    <meta property="og:url" content="https://gridironbrewing.ca" />
    <!-- Twitter/X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="Small-batch craft beer brewed in Hampton, New Brunswick. Cold pints, cozy place." />
    <meta name="twitter:image" content="/assets/logos/logo-favicon.png" />
    <!-- Theme colour for mobile browsers -->
    <meta name="theme-color" content="#c17a2b" />
    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
    {breadcrumb && <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />}
    <!-- Page-specific structured data slot -->
    <slot name="head" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:ital,wght@0,400;0,600;0,700;0,800;0,900;1,600&family=DM+Mono:wght@400;500&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:ital,wght@0,400;0,600;0,700;0,800;0,900;1,600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:ital,wght@0,400;0,600;0,700;0,800;0,900;1,600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" /></noscript>
  </head>
  <body>
    <script>
      // Load Netlify Identity widget only when an invite/recovery token is present
      if (window.location.hash && (
        window.location.hash.includes('invite_token') ||
        window.location.hash.includes('recovery_token')
      )) {
        const s = document.createElement('script');
        s.src = 'https://identity.netlify.com/v1/netlify-identity-widget.js';
        s.onload = () => {
          window.netlifyIdentity.on('init', (user: any) => {
            if (!user) window.netlifyIdentity.open();
          });
        };
        document.head.appendChild(s);
      }
    </script>
    <Navbar activeNav={activeNav} />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      const reveals = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window && reveals.length) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
        reveals.forEach((el) => io.observe(el));
      } else {
        reveals.forEach((el) => el.classList.add('in'));
      }
    </script>
  </body>
</html>
