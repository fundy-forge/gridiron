---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { siteUrl, DEFAULT_DESCRIPTION, DEFAULT_OG_IMAGE } from '../utils/constants';
import type { Schedule } from '../data/settings';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  activeNav?: string;
  hours?: Schedule | null;
}

const {
  title = 'Gridiron Brewing — Hampton, New Brunswick',
  description = DEFAULT_DESCRIPTION,
  ogImage = DEFAULT_OG_IMAGE,
  activeNav,
  hours,
} = Astro.props;

// Helper to convert "4:00 PM" to "16:00" for Schema.org
function to24h(timeStr: string) {
  if (!timeStr) return '00:00';
  const [time, modifier] = timeStr.split(' ');
  let [hours, minutes] = time.split(':');
  if (hours === '12') hours = '00';
  if (modifier === 'PM') hours = (parseInt(hours, 10) + 12).toString();
  return `${hours.padStart(2, '0')}:${minutes}`;
}

const openingHours = hours?.days.map(h => ({
  '@type': 'OpeningHoursSpecification',
  dayOfWeek: h.day,
  opens: h.isClosed ? '00:00' : to24h(h.opens),
  closes: h.isClosed ? '00:00' : to24h(h.closes),
})) || [
  { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Tuesday',   opens: '16:00', closes: '20:00' },
  { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Wednesday', opens: '16:00', closes: '20:00' },
  { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Thursday',  opens: '12:00', closes: '20:00' },
  { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Friday',    opens: '12:00', closes: '21:00' },
  { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Saturday',  opens: '12:00', closes: '21:00' },
  { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Sunday',    opens: '12:00', closes: '19:00' },
];

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'Brewery'],
  name: 'Gridiron Brewing',
  url: siteUrl,
  telephone: '+15068324592',
  email: 'info@gridironbrewing.com',
  image: `${siteUrl}/assets/logos/logo-favicon.png`,
  priceRange: '$$',
  description: 'Small-batch craft brewery and taproom in Hampton, New Brunswick — 25 minutes from uptown Saint John. Cold pints, patio on the Kennebecasis, live music most weekends.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '1051 Main Street',
    addressLocality: 'Hampton',
    addressRegion: 'NB',
    addressCountry: 'CA',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 45.5288,
    longitude: -65.8330,
  },
  areaServed: [
    { '@type': 'City', name: 'Hampton',    addressRegion: 'NB', addressCountry: 'CA' },
    { '@type': 'City', name: 'Saint John', addressRegion: 'NB', addressCountry: 'CA' },
  ],
  openingHoursSpecification: openingHours,
  sameAs: [
    'https://www.instagram.com/gridironbrewing/',
    'https://www.facebook.com/gridironbrewing/',
    'https://untappd.com/MatchstickBeerFactory',
  ],
};

const pathname = Astro.url.pathname;
const canonicalUrl = `${siteUrl}${pathname}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const pageLabels: Record<string, string> = {
  '/beers': 'Drinks',
  '/events': 'Events',
  '/visit': 'Visit',
  '/gallery': 'Gallery',
};
const pageLabel = Object.entries(pageLabels).find(([k]) => pathname.startsWith(k))?.[1];

const breadcrumb = pageLabel ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',     item: siteUrl },
    { '@type': 'ListItem', position: 2, name: pageLabel,  item: canonicalUrl },
  ],
} : null;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/assets/logos/logo-favicon.png" />
    <link rel="apple-touch-icon" href="/assets/logos/logo-favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Fundy Forge" />
    <!-- Designed & built by Fundy Forge — www.fundyforge.ca -->
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Gridiron Brewing" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <!-- Twitter/X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <!-- Theme colour for mobile browsers -->
    <meta name="theme-color" content="#c17a2b" />
    <!-- Structured data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
    {breadcrumb && <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />}
    <!-- Page-specific structured data slot -->
    <slot name="head" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:wght@400;700;800&family=DM+Mono:wght@400;500&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:wght@400;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:wght@400;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" /></noscript>
  </head>
  <body>
    <Navbar activeNav={activeNav} />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      import '../utils/reveal';
    </script>
  </body>
</html>
