---
interface Props { tag: 'flagship' | 'seasonal' | 'guest' | 'hidden'; }
const { tag } = Astro.props;
const label = tag === 'seasonal' ? 'Seasonal' : tag === 'guest' ? 'Guest' : 'Flagship';
const cls   = tag === 'seasonal' ? ' seasonal' : tag === 'guest' ? ' guest' : '';
---
<span class={`tag${cls}`}>{label}</span>
