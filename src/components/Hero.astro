---
import { TAP_COUNT } from '../utils/constants';
import { activeSchedule } from '../data/settings';

const openSummary = activeSchedule?.heroSummary || 'Tue–Sun';
---

<section class="hero grain">
  <div class="hero-bg">
    <img src="/assets/photos/crowded-bar.webp" alt="" aria-hidden="true" fetchpriority="high" loading="eager" decoding="async" />
  </div>
  <div class="inner">
    <span class="kicker">Small-Batch Craft Beer · Hampton, NB</span>
    <h1>Cold Pints,<br /><span class="rust">Cozy Place.</span></h1>
    <p class="sub">Paddle in, hike down, or just pull up a chair.</p>
    <div class="cta">
      <a class="btn btn-amber" href="/visit">Visit the Taproom →</a>
    </div>
    <div class="footstrip">
      <span>Open <b>{openSummary}</b></span>
      <span><b>{TAP_COUNT}</b> Taps Flowing</span>
      <span>Dog <b>Friendly</b></span>
      <span>Patio <b>on the River</b></span>
    </div>
  </div>
</section>
