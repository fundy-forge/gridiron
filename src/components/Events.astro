---
import { events } from '../data/events';
const upcoming = events.filter(e => !e.recurring).slice(0, 4);
const recurring = events.filter(e => e.recurring).slice(0, 3);
---

<section class="band-paper2" id="events">
  <div class="section">
  <div class="section-head">
    <span class="kicker reveal">Live At Gridiron</span>
    <h2 class="reveal d1">Events &amp; Music</h2>
    <p class="lead reveal d1">Something on most nights we're open. Live music every weekend, trivia midweek, and the occasional food truck. Always free to get in.</p>
  </div>
  <div class="event-list">
    {upcoming.map((ev, i) => (
      <div class={`event-row reveal${i > 0 ? ` d${Math.min(i, 3)}` : ''}`}>
        <div class="event-date">
          <span class="d">{ev.day}</span>
          <span class="m">{ev.month}</span>
        </div>
        <div class="event-body">
          <h4>{ev.title}</h4>
          <p>{ev.desc}</p>
        </div>
        <div class="event-meta">
          {ev.when}{ev.cover && <><br /><span class="free">{ev.cover}</span></>}
        </div>
      </div>
    ))}
  </div>

  <!-- Weekly regulars strip -->
  {recurring.length > 0 && (
    <div class="weekly-strip reveal d2">
      <span class="weekly-label">Every week</span>
      {recurring.map((ev) => (
        <div class="weekly-item">
          <span class="rec-icon">↻</span>
          <span class="weekly-title">{ev.title}</span>
          <span class="weekly-when">{ev.when}</span>
        </div>
      ))}
    </div>
  )}

  <div style="text-align:center;margin-top:40px;">
    <a class="btn btn-amber reveal" href="/events">Full Calendar →</a>
  </div>
  </div>
</section>

<style>
  .weekly-strip {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
    margin-top: 32px;
    border-top: 1px solid var(--line);
    padding-top: 20px;
  }
  .weekly-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--amber);
    margin-right: 20px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .weekly-item {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 16px;
    border-left: 1px solid var(--line);
  }
  .rec-icon {
    font-size: 14px;
    color: var(--amber);
    line-height: 1;
    flex-shrink: 0;
  }
  .weekly-title {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--ink);
    white-space: nowrap;
  }
  .weekly-when {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--ink-3);
    white-space: nowrap;
  }
  @media (max-width: 520px) {
    .weekly-strip {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
    }
    .weekly-item {
      border-left: none;
      padding: 4px 0;
    }
    .weekly-label {
      margin-bottom: 8px;
    }
  }
</style>
