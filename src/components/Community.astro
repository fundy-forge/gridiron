---
import communityData from '../data/community.json';
const photos = communityData.photos;
const initial = photos.slice(0, 6);
---

<section class="band-amber">
  <div class="section">
    <div class="community-outer" style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;">

      <!-- Text -->
      <div>
        <span class="kicker reveal" style="color:#5a2c14;">In The Community</span>
        <h2 class="display reveal d1" style="font-size:clamp(34px,5vw,72px);color:#1c130c;margin:16px 0 22px;line-height:0.92;">
          Drink Local.<br />Support Local.<br /><span style="color:#5a2c14;">Drink Gridiron.</span>
        </h2>
        <p class="reveal d1" style="max-width:480px;font-size:17px;line-height:1.65;color:#3a1f0e;">From live music to trivia nights to everyday visits, you've made this more than a place to grab a drink — you've made it a place to belong. Dogs, kids, and good people welcome.</p>
        <p class="reveal d2" style="margin-top:18px;">
          <a href="https://www.instagram.com/gridironbrewing/" target="_blank" rel="noopener"
            style="font-family:'Space Mono',monospace;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:#5a2c14;text-decoration:none;">
            Tag us @gridironbrewing →
          </a>
        </p>
      </div>

      <!-- Photo mosaic -->
      <div class="community-mosaic reveal d1" id="community-mosaic">
        {initial.map(p => (
          <div class="mosaic-item" data-src={p.src} data-alt={p.alt}>
            <img src={p.src} alt={p.alt} loading="lazy" decoding="async" />
          </div>
        ))}
      </div>
      <script type="application/json" id="community-pool">{JSON.stringify(photos)}</script>

      <!-- Lightbox overlay (mobile tap) -->
      <div id="community-lightbox" aria-hidden="true">
        <img id="community-lightbox-img" src="" alt="" />
      </div>

    </div>
  </div>
</section>

<style>
  .community-mosaic {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 1fr;
    gap: 8px;
    overflow: visible;
  }

  /* Force equal square cells */
  .community-mosaic::before {
    content: '';
    width: 0;
    padding-bottom: 100%;
    grid-row: 1;
    grid-column: 1;
  }
  .community-mosaic > *:first-child {
    grid-row: 1;
    grid-column: 1;
  }

  .mosaic-item {
    aspect-ratio: 1;
    position: relative;
    z-index: 1;
    overflow: hidden;
    cursor: zoom-in;
  }

  .mosaic-item:hover {
    overflow: visible;
    z-index: 10;
  }

  .mosaic-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s cubic-bezier(0.2, 0.7, 0.2, 1),
                box-shadow 0.4s cubic-bezier(0.2, 0.7, 0.2, 1),
                opacity 0.6s ease;
  }

  .mosaic-item:hover img {
    filter: brightness(0.85);
  }

  /* Lightbox */
  #community-lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 999;
    background: rgba(0, 0, 0, 0.88);
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
  }
  #community-lightbox.open {
    display: flex;
  }
  #community-lightbox-img {
    max-width: 92vw;
    max-height: 86vh;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.6);
  }

  .mosaic-item { cursor: zoom-in; }
</style>

<script>
  const lightbox = document.getElementById('community-lightbox');
  const lightboxImg = document.getElementById('community-lightbox-img') as HTMLImageElement | null;
  const mosaic = document.getElementById('community-mosaic');
  const poolEl = document.getElementById('community-pool');

  const pool: { src: string; alt: string }[] = poolEl ? JSON.parse(poolEl.textContent || '[]') : [];

  function bindLightbox(item: Element) {
    item.addEventListener('click', () => {
      if (!lightbox || !lightboxImg) return;
      lightboxImg.src = item.getAttribute('data-src') || '';
      lightboxImg.alt = item.getAttribute('data-alt') || '';
      lightbox.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
  }

  if (mosaic) {
    mosaic.querySelectorAll('.mosaic-item').forEach(bindLightbox);
  }

  if (lightbox && lightboxImg) {
    lightbox.addEventListener('click', () => {
      lightbox.classList.remove('open');
      document.body.style.overflow = '';
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { lightbox.classList.remove('open'); document.body.style.overflow = ''; }
    });
  }

  // Cycle one random slot every 3 seconds through the pool
  if (mosaic && pool.length > 6) {
    const shown = new Set(Array.from(mosaic.querySelectorAll('.mosaic-item')).map(el => el.getAttribute('data-src')));

    const cycleTimer = setInterval(() => {
      const items = Array.from(mosaic.querySelectorAll('.mosaic-item'));
      const slot = items[Math.floor(Math.random() * items.length)] as HTMLElement;
      const currentSrc = slot.getAttribute('data-src');
      const candidates = pool.filter(p => p.src !== currentSrc && !shown.has(p.src));
      const next = (candidates.length ? candidates : pool.filter(p => p.src !== currentSrc))[Math.floor(Math.random() * (candidates.length || pool.length - 1))];
      if (!next) return;

      shown.delete(currentSrc || '');
      shown.add(next.src);

      slot.style.transition = 'opacity 0.6s ease';
      slot.style.opacity = '0';
      setTimeout(() => {
        const img = slot.querySelector('img') as HTMLImageElement | null;
        if (img) { img.src = next.src; img.alt = next.alt; }
        slot.setAttribute('data-src', next.src);
        slot.setAttribute('data-alt', next.alt);
        slot.style.opacity = '1';
      }, 600);
    }, 3000);
    window.addEventListener('beforeunload', () => clearInterval(cycleTimer), { once: true });
  }
</script>
