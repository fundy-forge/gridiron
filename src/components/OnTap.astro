---
import { beers } from '../data/beers';
const onTap = beers.filter(b => b.onTap && b.tag !== 'hidden');
---

<section class="band-dark" id="beers">
  <div class="section">
    <div class="section-head" style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:20px;">
      <div>
        <span class="kicker reveal">On Tap Now</span>
        <h2 class="reveal d1">What's Pouring</h2>
      </div>
      <div style="display:flex;align-items:flex-end;gap:28px;flex-wrap:wrap;">
        <div class="reveal d1" style="display:flex;gap:20px;">
          <div style="text-align:center;">
            <p style="font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--amber-bright);margin:0 0 4px;">16 oz</p>
            <p style="font-size:26px;font-family:'Anton',sans-serif;color:var(--cream);margin:0;line-height:1;">$9</p>
          </div>
          <div style="text-align:center;">
            <p style="font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--amber-bright);margin:0 0 4px;">20 oz</p>
            <p style="font-size:26px;font-family:'Anton',sans-serif;color:var(--cream);margin:0;line-height:1;">$10</p>
          </div>
        </div>
        <a class="btn btn-amber reveal d1" href="/beers">Full Tap List →</a>
      </div>
    </div>
    <div class="beer-grid">
      {onTap.map((beer, i) => (
        <article class="beer-card reveal" style={`transition-delay:${Math.min(i,3) * 0.06}s`}>
          <div class="beer-info">
            <span class="style">{beer.style}</span>
            <h3>{beer.name}</h3>
            <p class="desc">{beer.desc}</p>
            <div class="beer-specs">
              <div class="spec"><span>ABV</span><b>{beer.abv}%</b></div>
              <div class="spec"><span>IBU</span><b>{beer.ibu}</b></div>
              <div class="tag-stack">
                <span class={`tag${beer.tag === 'seasonal' ? ' seasonal' : ''}`}>
                  {beer.tag === 'seasonal' ? 'Seasonal' : 'Flagship'}
                </span>
                <span class="tag ontap">On Tap</span>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
