---
interface Props {
  activeNav?: string;
}
const { activeNav } = Astro.props;

const navLinks = [
  { label: 'Drinks', href: '/beers' },
  { label: 'Food', href: '/visit#food' },
  { label: 'Events', href: '/events' },
  { label: 'Visit', href: '/visit' },
];
---

<header class="site-header">
  <div class="nav-inner">
    <a class="brand" href="/">
      <img class="wordmark" src="/assets/logos/logo-nav.webp" alt="Gridiron Brewing" width="950" height="399" />
    </a>
    <nav class="nav-links" id="nav-links">
      {navLinks.map(({ label, href }) => (
        <a href={href} class={activeNav === label ? 'active' : ''}>{label}</a>
      ))}
    </nav>
    <div class="nav-cta">
      <a class="btn btn-amber btn-sm" href="/visit#directions">Find Us →</a>
      <button class="menu-btn" aria-label="Menu" aria-expanded="false" aria-controls="nav-links">Menu</button>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector('.site-header');
  function onScroll() {
    if (!header) return;
    header.classList.toggle('scrolled', window.scrollY > 12);
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  const menuBtn = document.querySelector('.menu-btn') as HTMLButtonElement | null;
  const navLinks = document.querySelector('.nav-links');
  if (menuBtn && navLinks) {
    menuBtn.addEventListener('click', () => {
      const isOpen = navLinks.classList.toggle('open');
      menuBtn.setAttribute('aria-expanded', String(isOpen));
    });
    navLinks.querySelectorAll('a').forEach(a =>
      a.addEventListener('click', () => {
        navLinks.classList.remove('open');
        menuBtn.setAttribute('aria-expanded', 'false');
      })
    );

    document.addEventListener('click', (e) => {
      if (!navLinks.classList.contains('open')) return;
      const header = document.querySelector('.site-header');
      if (header && !header.contains(e.target as Node)) {
        navLinks.classList.remove('open');
        menuBtn.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>
